<UserControl
    x:Class="WpfTabNavigation.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:properties="clr-namespace:WpfTabNavigation.Properties"
    xmlns:prism="http://prismlibrary.com/"
    Style="{StaticResource BaseUserControlStyle}"
    mc:Ignorable="d"
    d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <!-- 둥근 탭 아이템 스타일 -->
        <Style x:Key="RoundedTabItemStyle" TargetType="TabItem">
            <Setter Property="Header" Value="{Binding DataContext.Title}" />
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Margin" Value="0 0 1 0"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <!-- 기본 비활성 배경 -->
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid x:Name="Root">
                            <!-- CornerRadius로 상단만 둥글게 설정 (왼쪽위, 오른쪽위, 오른쪽아래, 왼쪽아래) -->
                            <Border x:Name="MainBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="10,10,0,0" 
                                Padding="{TemplateBinding Padding}">
                                <ContentPresenter x:Name="ContentSite"
                                            ContentSource="Header"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- 마우스 오버 -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <!-- 선택되었을 때 -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2196F3"/>
                                <!-- 포인트 컬러 (파랑) -->
                                <Setter TargetName="ContentSite" Property="TextBlock.Foreground" Value="White"/>
                                <Setter TargetName="ContentSite" Property="TextBlock.FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 탭 아이템 스타일 -->
        <Style x:Key="ModernTabItemStyle" TargetType="TabItem">
            <Setter Property="Header" Value="{Binding DataContext.Title}" />
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,3"/>
            <!-- 하단 강조 선 -->
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid x:Name="Root" Background="{TemplateBinding Background}">
                            <Border x:Name="Indicator" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Padding="{TemplateBinding Padding}">
                                <ContentPresenter x:Name="ContentSite"
                                            ContentSource="Header"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- 마우스 올렸을 때 -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F0F0"/>
                                <Setter TargetName="ContentSite" Property="TextBlock.Foreground" Value="#2196F3"/>
                            </Trigger>
                            <!-- 선택되었을 때 -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="BorderBrush" Value="#2196F3"/>
                                <!-- 포인트 컬러 (파랑) -->
                                <Setter TargetName="ContentSite" Property="TextBlock.Foreground" Value="#2196F3"/>
                                <Setter TargetName="ContentSite" Property="TextBlock.FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 탭 컨트롤 스타일 (기본 배경 및 테두리 제거) -->
        <Style x:Key="ModernTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Gainsboro"/>
            <Setter Property="Padding" Value="0 10 0 0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock
            Style="{StaticResource PageTitleStyle}"
            Margin="{StaticResource MediumLeftMargin}"
            Text="{x:Static properties:Resources.MainPageTitle}" />

        <!-- TabControl을 Region으로 설정 -->
        <TabControl Grid.Row="1" prism:RegionManager.RegionName="tabContentRegion" Style="{StaticResource ModernTabControlStyle}" ItemContainerStyle="{StaticResource RoundedTabItemStyle}" />
        
    </Grid>
</UserControl>
